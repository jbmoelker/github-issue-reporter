  "dependencies": {
    "@github-issue-reporter/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "nitropack": "^2.9.7",
    "typescript": "^5.5.0",
    "wrangler": "^4.83.0"
  }
}
