# GitHub OAuth App credentials
# Personal: https://github.com/settings/applications/new
# Org:      https://github.com/organizations/YOUR_ORG/settings/applications/new
# Callback URL: http://localhost:3001/auth/callback (dev) + your production URL
NITRO_GITHUB_CLIENT_ID=your_github_oauth_app_client_id
NITRO_GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Port for the dev server (must match PLASMO_PUBLIC_API_URL in the extension .env)
PORT=3001

# Public base URL of this API (used to build the OAuth redirect_uri)
# Override only if deploying somewhere other than localhost:PORT
# NITRO_API_BASE_URL=https://your-deployed-api.example.com
