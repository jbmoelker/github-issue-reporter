{
  "name": "@github-issue-reporter/extension",
  "displayName": "GitHub Issue Reporter",
  "version": "0.1.0",
  "description": "Report GitHub issues directly from your browser",
  "private": true,
  "scripts": {
    "predev": "node -e \"require('fs').cpSync('assets/icon-dev', 'assets/icon', {recursive: true, force: true})\"",
    "prebuild": "node -e \"require('fs').cpSync('assets/icon-prod', 'assets/icon', {recursive: true, force: true})\"",
    "dev": "plasmo dev",
    "build": "plasmo build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@github-issue-reporter/shared": "workspace:*",
    "@headlessui/react": "^2.1.2",
    "lucide-react": "^0.441.0",
    "@octokit/rest": "^21.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-select": "^5.8.0",
    "fabric": "^6.5.4"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "plasmo": "^0.90.4",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0"
  },
  "manifest": {
    "permissions": ["storage", "tabs", "activeTab"],
    "host_permissions": [
      "https://api.github.com/*",
      "https://uploads.github.com/*",
      "http://localhost:3001/*",
      "https://*.workers.dev/*"
    ],
    "icons": {
      "16": "../assets/icon/favicon-16x16.png",
      "32": "../assets/icon/favicon-32x32.png",
      "48": "../assets/icon/android-chrome-192x192.png",
      "128": "../assets/icon/android-chrome-512x512.png"
    },
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "../assets/icon/favicon-16x16.png",
        "32": "../assets/icon/favicon-32x32.png"
      }
    }
  }
}
